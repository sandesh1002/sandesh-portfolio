# ──────────────────────────────────────────────
# Sandesh Portfolio — Backend Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ──────────────────────────────────────────────

# MongoDB Atlas connection string (required)
# Get yours at https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# Gmail credentials for sending emails (optional — without these the contact form
# will still save messages to the database, but email notifications are skipped)
GMAIL_USER=sandeshjadhavv1002@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# The email address that receives contact form notifications (optional)
OWNER_EMAIL=sandeshjadhavv1002@gmail.com

# Frontend URL for CORS (optional — defaults to http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Server port (optional — defaults to 5000)
PORT=5000

